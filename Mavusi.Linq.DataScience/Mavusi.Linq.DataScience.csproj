<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>

    <!-- NuGet Package Metadata -->
    <PackageId>Mavusi.Linq.DataScience</PackageId>
    <Version>1.7.0</Version>
    <Authors>Mavusi</Authors>
    <Company>Mavusi</Company>
    <Description>A comprehensive .NET library that extends LINQ to Objects with powerful statistical and data science features including distribution analysis (median, quartiles, percentiles, skewness, kurtosis), standard deviation, correlation, rolling windows, time-series analysis, linear algebra operations, and geospatial analysis (Haversine distance, radius filtering, nearest neighbor search, bounding boxes, route calculations).</Description>
    <PackageTags>linq;data-science;statistics;correlation;time-series;rolling-windows;linear-algebra;machine-learning;analytics;math;median;quartiles;percentiles;distribution;skewness;kurtosis;geospatial;gis;haversine;location;gps;mapping;distance;coordinates</PackageTags>
    <PackageProjectUrl>https://github.com/mavusi/Mavusi.Linq.DataScience</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mavusi/Mavusi.Linq.DataScience</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Version 1.7.0: Added comprehensive Geospatial Extensions including Haversine distance calculations (km/miles), radius-based filtering, nearest neighbor search, geographic center/centroid, bounding boxes, route distance calculations, proximity clustering, and more. Perfect for location-based queries, delivery radius calculations, trip planning, and spatial analysis. Includes 23 new tests with full coverage.</PackageReleaseNotes>
    <Copyright>Copyright (c) 2025 Mavusi</Copyright>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ILGPU" Version="1.5.3" />
    <PackageReference Include="ILGPU.Algorithms" Version="1.5.3" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

</Project>
