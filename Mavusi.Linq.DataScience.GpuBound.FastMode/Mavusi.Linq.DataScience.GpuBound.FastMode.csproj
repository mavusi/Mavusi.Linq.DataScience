<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>

    <!-- NuGet Package Metadata -->
    <PackageId>Mavusi.Linq.DataScience.GpuBound.FastMode</PackageId>
    <Version>1.0.1</Version>
    <Authors>Mavusi</Authors>
    <Company>Mavusi</Company>
    <Description>Ultra-fast GPU-accelerated data science extensions using 32-bit float precision for maximum performance. This FastMode variant of Mavusi.Linq.DataScience.GpuBound trades 64-bit double precision for 32-bit float precision, delivering 2-4x faster processing and 50% lower VRAM usage—ideal for large-scale analytics where speed matters more than precision. Leverages ILGPU for GPU parallel processing with up to 200x performance gains on massive datasets. Includes GPU-accelerated float-based versions of: correlation, covariance, standard deviation, variance, distribution analysis (median, quartiles, percentiles, skewness, kurtosis), rolling windows, time-series operations, linear algebra (dot product, matrix multiplication, vector operations), and geospatial calculations (Haversine distance, radius filtering, nearest neighbor). All GPU methods are suffixed with 'Gpu' and automatically handle hardware compatibility with CUDA, OpenCL, or CPU fallback. Returns float results for 6-7 significant digits of precision (vs 15-16 digits for double precision). Perfect for machine learning pipelines, real-time analytics, and large-scale data processing where performance is critical.</Description>
    <PackageTags>gpu;cuda;opencl;ilgpu;parallel;high-performance;acceleration;hpc;data-science;statistics;correlation;linear-algebra;machine-learning;analytics;math;median;quartiles;distribution;geospatial;time-series;rolling-windows;linq;float;fast;performance;memory-efficient;32-bit;single-precision</PackageTags>
    <PackageProjectUrl>https://github.com/mavusi/Mavusi.Linq.DataScience</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mavusi/Mavusi.Linq.DataScience</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Version 1.0.0: FastMode variant using 32-bit float precision for 2-4x faster GPU processing and 50% lower VRAM usage compared to 64-bit double precision. Targets .NET 8. All GPU methods provide up to 200x performance improvement on large datasets. Returns float (6-7 digit precision) instead of double (15-16 digit precision). Ideal for machine learning, real-time analytics, and large-scale processing where speed trumps precision. Install alongside Mavusi.Linq.DataScience.GpuBound.Accurate when you need maximum performance.</PackageReleaseNotes>
    <Copyright>Copyright (c) 2025 Mavusi</Copyright>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ILGPU" Version="1.5.3" />
    <PackageReference Include="ILGPU.Algorithms" Version="1.5.3" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mavusi.Linq.DataScience.Models\Mavusi.Linq.DataScience.Models.csproj" />
  </ItemGroup>

</Project>
